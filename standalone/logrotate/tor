/var/log/tor/*log {
    daily
    rotate 5
    compress
    delaycompress
    missingok
    notifempty
    create 0640 tor adm
    sharedscripts
    postrotate
        if /usr/sbin/dinitctl is-started tor > /dev/null; then
            /usr/sbin/dinitctl signal USR1 tor > /dev/null
        fi
    endscript
}
